# Triton bring-up for Blackwell sm_121 (GB10 / DGX Spark / consumer Blackwell)
# Source this file:
#     . ./bringup.env
#
# Requires CUDA 13.0+ system ptxas (which ships with sm_121 support).
# Verified on PyTorch 2.9.0+cu130 / Triton 3.5 / Ubuntu 24.04.

if [ -x /usr/local/cuda/bin/ptxas ]; then
    export TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas
fi

case ":${TORCH_CUDA_ARCH_LIST}:" in
    *:12.1+PTX:*) ;;
    *) export TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH_LIST:+$TORCH_CUDA_ARCH_LIST;}12.1+PTX" ;;
esac

# IMPORTANT: do not override the Triton target arch — earlier bring-up
# attempts that pointed at sm_90 produced kernels the device can't load.
unset TRITON_OVERRIDE_ARCH
